{
  "name": "claude",
  "root": "../../../../claude",
  "startupPath": "/",
  "host": "127.0.0.1",
  "port": 6180,
  "stateGlobals": ["state", "appState", "spineState"],
  "volatileFields": [
    "debugSnapshot.value.currentAnimId",
    "debugSnapshot.value.animTime",
    "debugTiming.value",
    "debugMethodResults.timing.value",
    "debugMethodResults.snapshot.value.currentAnimId",
    "debugMethodResults.snapshot.value.animTime",
    "debugMethodResults.animations.value"
  ],
  "debugMethods": [
    "snapshot",
    "mesh",
    "slots",
    "bones",
    "constraints",
    "animations",
    "actionLog",
    "errors",
    "warnings",
    "timing"
  ],
  "consoleIgnorePatterns": [
    "Automatic fallback to software WebGL",
    "CONTEXT_LOST_WEBGL",
    "GroupMarkerNotSet",
    "context lost",
    "context restored",
    "GPU stall",
    "resources rebuilt"
  ],
  "passiveProbes": {
    "domSnapshot": true,
    "domSelectors": [
      "#appRoot",
      "#workspaceTabRig",
      "#workspaceTabSlot",
      "#workspaceTabObject",
      "#leftTabRig",
      "#addBoneBtn",
      "#fileInput",
      "#overlay"
    ],
    "storage": true,
    "windowGlobalsScan": true,
    "network": true
  },
  "environmentCapture": {
    "localStorage": {
      "mode": "allowlist",
      "keys": [
        "mesh_deformer_autosave_v1",
        "uiLayout:v3"
      ]
    },
    "sessionStorage": {
      "mode": "none"
    },
    "maxValueBytes": 5000000
  },
  "fileCapture": {
    "mode": "allowlist",
    "selectors": [
      "#fileInput",
      "#projectLoadInput"
    ],
    "maxFileBytes": 10000000,
    "maxFiles": 4
  }
}
